# ── BIF Hub — environment variables ──
# Copy to .env.local for local dev (it is gitignored).

# The standalone BIF marketing site. The "Website" card (homepage + footer)
# opens this URL in a new tab. Defaults to http://localhost:3000 in dev.
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# Rigpai chat — OpenAI API key. If unset, the chat falls back to grounded
# knowledge-base summaries (no LLM). Server-only; never exposed to the browser.
OPENAI_API_KEY=
